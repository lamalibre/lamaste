    {
      "id": "panel-survives-all-service-disruptions",
      "label": "Panel survives all service disruptions",
      "steps": [
        {
          "id": "step-52",
          "label": "GET /api/health",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "health"
          },
          "capture": [
            {
              "variable": "HEALTH_FINAL",
              "from": {
