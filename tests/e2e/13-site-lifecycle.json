{
  "version": 1,
  "meta": {
    "number": 13,
    "name": "Site Lifecycle",
    "suite": "e2e",
    "description": "13 — Site Lifecycle",
    "deps": [],
    "requires": ["curl", "jq"]
  },
  "env": {},
  "constants": {},
  "cleanup": [
    {
      "id": "cleanup-0",
      "label": "DELETE sites/${SITE_ID}",
      "target": "host",
      "continueOnError": true,
      "op": {
        "type": "api",
        "method": "DELETE",
        "path": "sites/${SITE_ID}"
      }
    }
  ],
  "sections": [
    {
      "id": "pre-flight-check-onboarding-is-complete",
      "label": "Pre-flight: check onboarding is complete",
      "steps": [
        {
          "id": "step-0",
          "label": "GET /api/onboarding/status",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "onboarding/status"
          },
          "capture": [
            {
              "variable": "ONBOARDING_STATUS",
              "from": {
                "kind": "jq",
                "expression": ".status"
              }
            }
          ]
        },
        {
          "id": "step-1",
          "label": "Onboarding is complete",
          "target": "local",
          "op": {
            "type": "log",
            "level": "pass",
            "message": "Onboarding is complete"
          }
        }
      ],
      "when": {
        "kind": "var_eq",
        "variable": "ONBOARDING_STATUS",
        "value": "COMPLETED"
      },
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Pre-flight: check onboarding is complete\"\n# ---------------------------------------------------------------------------\n\nONBOARDING_STATUS=$(api_get \"onboarding/status\" | jq -r '.status' 2>/dev/null || echo \"unknown\")\nif [ \"$ONBOARDING_STATUS\" != \"COMPLETED\" ]; then\n  log_skip \"Onboarding not completed — skipping site tests\"\n  end_test\n  exit $?\nfi\nlog_pass \"Onboarding is complete\""
    },
    {
      "id": "create-managed-static-site",
      "label": "Create managed static site",
      "steps": [
        {
          "id": "step-3",
          "label": "POST /api/sites",
          "target": "host",
          "op": {
            "type": "api",
            "method": "POST",
            "path": "sites",
            "body": "{\\"
          },
          "capture": [
            {
              "variable": "CREATE_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-4",
          "label": "Site creation returned ok: true",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "CREATE_RESPONSE"
              },
              "path": ".ok",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "Site creation returned ok: true"
            }
          }
        },
        {
          "id": "step-5",
          "label": "Extract SITE_ID",
          "target": "local",
          "op": {
            "type": "set",
            "variable": "SITE_ID",
            "from": {
              "kind": "jq",
              "input": {
                "kind": "var",
                "name": "CREATE_RESPONSE"
              },
              "expression": ".site.id"
            }
          }
        },
        {
          "id": "step-6",
          "label": "Site has an ID",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field_not_empty",
              "source": {
                "kind": "var",
                "name": "CREATE_RESPONSE"
              },
              "path": ".site.id",
              "message": "Site has an ID"
            }
          }
        },
        {
          "id": "step-7",
          "label": "Site name matches",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "CREATE_RESPONSE"
              },
              "path": ".site.name",
              "expected": {
                "kind": "var",
                "name": "SITE_NAME"
              },
              "message": "Site name matches"
            }
          }
        },
        {
          "id": "step-8",
          "label": "Site type is managed",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "CREATE_RESPONSE"
              },
              "path": ".site.type",
              "expected": {
                "kind": "literal",
                "value": "managed"
              },
              "message": "Site type is managed"
            }
          }
        },
        {
          "id": "step-9",
          "label": "Extract SITE_FQDN",
          "target": "local",
          "op": {
            "type": "set",
            "variable": "SITE_FQDN",
            "from": {
              "kind": "jq",
              "input": {
                "kind": "var",
                "name": "CREATE_RESPONSE"
              },
              "expression": ".site.fqdn"
            }
          }
        },
        {
          "id": "step-10",
          "label": "Created site: ${SITE_FQDN} (ID: ${SITE_ID})",
          "target": "local",
          "op": {
            "type": "log",
            "level": "info",
            "message": "Created site: ${SITE_FQDN} (ID: ${SITE_ID})"
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Create managed static site\"\n# ---------------------------------------------------------------------------\n\nSITE_NAME=\"e2esite\"\nCREATE_RESPONSE=$(api_post \"sites\" \"{\\\"name\\\":\\\"${SITE_NAME}\\\",\\\"type\\\":\\\"managed\\\",\\\"spaMode\\\":false,\\\"autheliaProtected\\\":false}\")\nassert_json_field \"$CREATE_RESPONSE\" '.ok' 'true' \"Site creation returned ok: true\" || true\n\nSITE_ID=$(echo \"$CREATE_RESPONSE\" | jq -r '.site.id' 2>/dev/null || echo \"\")\nassert_json_field_not_empty \"$CREATE_RESPONSE\" '.site.id' \"Site has an ID\" || true\nassert_json_field \"$CREATE_RESPONSE\" '.site.name' \"$SITE_NAME\" \"Site name matches\" || true\nassert_json_field \"$CREATE_RESPONSE\" '.site.type' \"managed\" \"Site type is managed\" || true\n\nSITE_FQDN=$(echo \"$CREATE_RESPONSE\" | jq -r '.site.fqdn' 2>/dev/null || echo \"\")\nlog_info \"Created site: ${SITE_FQDN} (ID: ${SITE_ID})\"\n\n# Cleanup function\ncleanup() {\n  if [ -n \"$SITE_ID\" ] && [ \"$SITE_ID\" != \"null\" ]; then\n    api_delete \"sites/${SITE_ID}\" 2>/dev/null || true\n  fi\n}\ntrap cleanup EXIT"
    },
    {
      "id": "verify-site-in-listing",
      "label": "Verify site in listing",
      "steps": [
        {
          "id": "step-11",
          "label": "GET /api/sites",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "sites"
          },
          "capture": [
            {
              "variable": "SITES_LIST",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-12",
          "label": "Set FOUND_SITE",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "echo \"$SITES_LIST\" | jq -r \".sites[] | select(.id == \\\"${SITE_ID}\\\") | .name\" 2>/dev/null || echo \"\""
          },
          "capture": [
            {
              "variable": "FOUND_SITE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-13",
          "label": "Site appears in listing",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "FOUND_SITE"
              },
              "expected": {
                "kind": "var",
                "name": "SITE_NAME"
              },
              "message": "Site appears in listing"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Verify site in listing\"\n# ---------------------------------------------------------------------------\n\nSITES_LIST=$(api_get \"sites\")\nFOUND_SITE=$(echo \"$SITES_LIST\" | jq -r \".sites[] | select(.id == \\\"${SITE_ID}\\\") | .name\" 2>/dev/null || echo \"\")\nassert_eq \"$FOUND_SITE\" \"$SITE_NAME\" \"Site appears in listing\" || true"
    },
    {
      "id": "list-files-default-content",
      "label": "List files — default content",
      "steps": [
        {
          "id": "step-14",
          "label": "GET /api/sites/${SITE_ID}/files?path=.",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "sites/${SITE_ID}/files?path=."
          },
          "capture": [
            {
              "variable": "FILES_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-15",
          "label": "Set FILE_COUNT",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "echo \"$FILES_RESPONSE\" | jq '.files | length' 2>/dev/null || echo \"0\""
          },
          "capture": [
            {
              "variable": "FILE_COUNT",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-16",
          "label": "Site has default files (count: ${FILE_COUNT})",
          "target": "local",
          "op": {
            "type": "log",
            "level": "pass",
            "message": "Site has default files (count: ${FILE_COUNT})"
          }
        },
        {
          "id": "step-17",
          "label": "Site has no default files",
          "target": "local",
          "op": {
            "type": "log",
            "level": "fail",
            "message": "Site has no default files"
          }
        },
        {
          "id": "step-18",
          "label": "Extract DEFAULT_FILE",
          "target": "local",
          "op": {
            "type": "set",
            "variable": "DEFAULT_FILE",
            "from": {
              "kind": "jq",
              "input": {
                "kind": "var",
                "name": "FILES_RESPONSE"
              },
              "expression": ".files[] | select(.name == \"index.html\") | .name"
            }
          }
        },
        {
          "id": "step-19",
          "label": "Default index.html exists",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "DEFAULT_FILE"
              },
              "expected": {
                "kind": "literal",
                "value": "index.html"
              },
              "message": "Default index.html exists"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"List files — default content\"\n# ---------------------------------------------------------------------------\n\nFILES_RESPONSE=$(api_get \"sites/${SITE_ID}/files?path=.\")\nFILE_COUNT=$(echo \"$FILES_RESPONSE\" | jq '.files | length' 2>/dev/null || echo \"0\")\nif [ \"$FILE_COUNT\" -gt 0 ]; then\n  log_pass \"Site has default files (count: ${FILE_COUNT})\"\nelse\n  log_fail \"Site has no default files\"\nfi\n\nDEFAULT_FILE=$(echo \"$FILES_RESPONSE\" | jq -r '.files[] | select(.name == \"index.html\") | .name' 2>/dev/null || echo \"\")\nassert_eq \"$DEFAULT_FILE\" \"index.html\" \"Default index.html exists\" || true"
    },
    {
      "id": "upload-test-file",
      "label": "Upload test file",
      "steps": [
        {
          "id": "step-20",
          "label": "Set TEST_FILE",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "mktemp /tmp/e2e-site-test-XXXXXX.html"
          },
          "capture": [
            {
              "variable": "TEST_FILE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-22",
          "label": "Set UPLOAD_RESPONSE",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "api_upload_file \"sites/${SITE_ID}/files?path=.\" \"$TEST_FILE\""
          },
          "capture": [
            {
              "variable": "UPLOAD_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-23",
          "label": "Set UPLOADED_BASENAME",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "basename \"$TEST_FILE\""
          },
          "capture": [
            {
              "variable": "UPLOADED_BASENAME",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-25",
          "label": "File upload returned ok: true",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "UPLOAD_RESPONSE"
              },
              "path": ".ok",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "File upload returned ok: true"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Upload test file\"\n# ---------------------------------------------------------------------------\n\nTEST_FILE=$(mktemp /tmp/e2e-site-test-XXXXXX.html)\necho \"<html><body><h1>E2E Test</h1></body></html>\" > \"$TEST_FILE\"\nUPLOAD_RESPONSE=$(api_upload_file \"sites/${SITE_ID}/files?path=.\" \"$TEST_FILE\")\nUPLOADED_BASENAME=$(basename \"$TEST_FILE\")\nrm -f \"$TEST_FILE\"\nassert_json_field \"$UPLOAD_RESPONSE\" '.ok' 'true' \"File upload returned ok: true\" || true"
    },
    {
      "id": "verify-uploaded-file-in-listing",
      "label": "Verify uploaded file in listing",
      "steps": [
        {
          "id": "step-26",
          "label": "GET /api/sites/${SITE_ID}/files?path=.",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "sites/${SITE_ID}/files?path=."
          },
          "capture": [
            {
              "variable": "FILES_AFTER_UPLOAD",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-27",
          "label": "Set FOUND_UPLOAD",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "echo \"$FILES_AFTER_UPLOAD\" | jq -r \".files[] | select(.name == \\\"${UPLOADED_BASENAME}\\\") | .name\" 2>/dev/null || echo \"\""
          },
          "capture": [
            {
              "variable": "FOUND_UPLOAD",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-28",
          "label": "Uploaded file appears in listing",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "FOUND_UPLOAD"
              },
              "expected": {
                "kind": "var",
                "name": "UPLOADED_BASENAME"
              },
              "message": "Uploaded file appears in listing"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Verify uploaded file in listing\"\n# ---------------------------------------------------------------------------\n\nFILES_AFTER_UPLOAD=$(api_get \"sites/${SITE_ID}/files?path=.\")\nFOUND_UPLOAD=$(echo \"$FILES_AFTER_UPLOAD\" | jq -r \".files[] | select(.name == \\\"${UPLOADED_BASENAME}\\\") | .name\" 2>/dev/null || echo \"\")\nassert_eq \"$FOUND_UPLOAD\" \"$UPLOADED_BASENAME\" \"Uploaded file appears in listing\" || true"
    },
    {
      "id": "delete-uploaded-file",
      "label": "Delete uploaded file",
      "steps": [
        {
          "id": "step-29",
          "label": "Set DELETE_FILE_RESPONSE",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls -X DELETE -H \"Content-Type: application/json\" -d \"{\\\"path\\\":\\\"${UPLOADED_BASENAME}\\\"}\" \"${BASE_URL}/api/sites/${SITE_ID}/files\""
          },
          "capture": [
            {
              "variable": "DELETE_FILE_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-30",
          "label": "File deletion returned ok: true",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "DELETE_FILE_RESPONSE"
              },
              "path": ".ok",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "File deletion returned ok: true"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Delete uploaded file\"\n# ---------------------------------------------------------------------------\n\nDELETE_FILE_RESPONSE=$(_curl_mtls \\\n  -X DELETE \\\n  -H \"Content-Type: application/json\" \\\n  -d \"{\\\"path\\\":\\\"${UPLOADED_BASENAME}\\\"}\" \\\n  \"${BASE_URL}/api/sites/${SITE_ID}/files\")\nassert_json_field \"$DELETE_FILE_RESPONSE\" '.ok' 'true' \"File deletion returned ok: true\" || true"
    },
    {
      "id": "verify-file-removed",
      "label": "Verify file removed",
      "steps": [
        {
          "id": "step-31",
          "label": "GET /api/sites/${SITE_ID}/files?path=.",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "sites/${SITE_ID}/files?path=."
          },
          "capture": [
            {
              "variable": "FILES_AFTER_DELETE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-32",
          "label": "Set FOUND_DELETED",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "echo \"$FILES_AFTER_DELETE\" | jq -r \".files[] | select(.name == \\\"${UPLOADED_BASENAME}\\\") | .name\" 2>/dev/null || echo \"\""
          },
          "capture": [
            {
              "variable": "FOUND_DELETED",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-33",
          "label": "Deleted file no longer in listing",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "FOUND_DELETED"
              },
              "expected": {
                "kind": "literal",
                "value": ""
              },
              "message": "Deleted file no longer in listing"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Verify file removed\"\n# ---------------------------------------------------------------------------\n\nFILES_AFTER_DELETE=$(api_get \"sites/${SITE_ID}/files?path=.\")\nFOUND_DELETED=$(echo \"$FILES_AFTER_DELETE\" | jq -r \".files[] | select(.name == \\\"${UPLOADED_BASENAME}\\\") | .name\" 2>/dev/null || echo \"\")\nassert_eq \"$FOUND_DELETED\" \"\" \"Deleted file no longer in listing\" || true"
    },
    {
      "id": "update-site-settings",
      "label": "Update site settings",
      "steps": [
        {
          "id": "step-34",
          "label": "PATCH /api/sites/${SITE_ID}",
          "target": "host",
          "op": {
            "type": "api",
            "method": "PATCH",
            "path": "sites/${SITE_ID}",
            "body": {
              "spaMode": true
            }
          },
          "capture": [
            {
              "variable": "PATCH_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-35",
          "label": "Settings update returned ok: true",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "PATCH_RESPONSE"
              },
              "path": ".ok",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "Settings update returned ok: true"
            }
          }
        },
        {
          "id": "step-36",
          "label": "SPA mode is now enabled",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "PATCH_RESPONSE"
              },
              "path": ".site.spaMode",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "SPA mode is now enabled"
            }
          }
        },
        {
          "id": "step-37",
          "label": "GET /api/sites",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "sites"
          },
          "capture": [
            {
              "variable": "SITE_DETAIL",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-38",
          "label": "SPA mode persisted in listing",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "SITE_DETAIL"
              },
              "path": ".spaMode",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "SPA mode persisted in listing"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Update site settings\"\n# ---------------------------------------------------------------------------\n\nPATCH_RESPONSE=$(api_patch \"sites/${SITE_ID}\" '{\"spaMode\":true}')\nassert_json_field \"$PATCH_RESPONSE\" '.ok' 'true' \"Settings update returned ok: true\" || true\nassert_json_field \"$PATCH_RESPONSE\" '.site.spaMode' 'true' \"SPA mode is now enabled\" || true\n\n# Verify settings persisted\nSITE_DETAIL=$(api_get \"sites\" | jq \".sites[] | select(.id == \\\"${SITE_ID}\\\")\")\nassert_json_field \"$SITE_DETAIL\" '.spaMode' 'true' \"SPA mode persisted in listing\" || true"
    },
    {
      "id": "file-extension-validation",
      "label": "File extension validation",
      "steps": [
        {
          "id": "step-39",
          "label": "Set PHP_FILE",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "mktemp /tmp/e2e-site-test-XXXXXX.php"
          },
          "capture": [
            {
              "variable": "PHP_FILE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-41",
