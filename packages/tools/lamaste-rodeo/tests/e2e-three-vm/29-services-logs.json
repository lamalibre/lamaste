          }
        },
        {
          "id": "step-authelia-close-1000",
          "label": "authelia close code 1000",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_AUTHELIA_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1000"
              },
              "message": "authelia logs stream closes with code 1000 (normal)"
            }
          }
        },
        {
          "id": "step-connect-chisel",
          "label": "Connect WS to /api/services/chisel/logs",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs chisel 4000"
          },
          "capture": [
            {
              "variable": "WS_CHISEL_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-chisel-opened",
          "label": "chisel WS opened",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_CHISEL_RESPONSE"
              },
              "path": ".opened",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "WebSocket upgrade succeeds for chisel (opened: true)"
            }
          }
        },
        {
          "id": "step-chisel-close-1000",
          "label": "chisel close code 1000",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_CHISEL_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1000"
              },
              "message": "chisel logs stream closes with code 1000 (normal)"
            }
          }
        },
        {
          "id": "step-connect-panel",
          "label": "Connect WS to /api/services/lamalibre-lamaste-serverd/logs",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs lamalibre-lamaste-serverd 4000"
          },
          "capture": [
            {
              "variable": "WS_PANEL_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-panel-opened",
          "label": "lamalibre-lamaste-serverd WS opened",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_PANEL_RESPONSE"
              },
              "path": ".opened",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "WebSocket upgrade succeeds for lamalibre-lamaste-serverd (opened: true)"
            }
          }
        },
        {
          "id": "step-panel-close-1000",
          "label": "lamalibre-lamaste-serverd close code 1000",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_PANEL_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1000"
              },
              "message": "lamalibre-lamaste-serverd logs stream closes with code 1000 (normal)"
            }
          }
        }
      ]
    },
    {
      "id": "error-unknown-service",
      "label": "Error path: unknown service rejected",
      "steps": [
        {
          "id": "step-connect-unknown",
          "label": "Connect WS to /api/services/nonexistent/logs",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs nonexistent 4000"
          },
          "capture": [
            {
              "variable": "WS_UNKNOWN_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-unknown-close-1008",
          "label": "Unknown service closes with 1008",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_UNKNOWN_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1008"
              },
              "message": "Unknown service name closes WebSocket with code 1008 (policy violation)"
            }
          }
        },
        {
          "id": "step-unknown-reason",
          "label": "Unknown service close reason is 'Unknown service'",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_UNKNOWN_RESPONSE"
              },
              "path": ".closeReason",
              "expected": {
                "kind": "literal",
                "value": "Unknown service"
              },
              "message": "Unknown service close reason is the expected 'Unknown service'"
            }
          }
        },
        {
          "id": "step-unknown-no-messages",
          "label": "No log messages sent for unknown service",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_UNKNOWN_RESPONSE"
              },
              "path": ".count",
              "expected": {
                "kind": "literal",
                "value": "0"
              },
              "message": "No log messages are streamed for an unknown service name"
            }
          }
        }
      ]
    },
    {
      "id": "error-path-injection",
      "label": "Error path: path injection rejected",
      "steps": [
        {
          "id": "step-connect-injection",
          "label": "Connect WS to /api/services/..%2Fetc%2Fpasswd/logs",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs '..%2Fetc%2Fpasswd' 4000"
          },
          "capture": [
            {
              "variable": "WS_INJECTION_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-injection-close-1008",
          "label": "Path injection closes with 1008",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_INJECTION_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1008"
              },
              "message": "Path traversal attempt (..%2Fetc%2Fpasswd) closes WebSocket with code 1008"
            }
          }
        },
        {
          "id": "step-injection-reason",
          "label": "Path injection close reason is 'Unknown service'",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_INJECTION_RESPONSE"
              },
              "path": ".closeReason",
              "expected": {
                "kind": "literal",
                "value": "Unknown service"
              },
              "message": "Path traversal attempt is rejected with 'Unknown service' close reason (allowlist guard)"
            }
          }
        },
        {
          "id": "step-injection-no-messages",
          "label": "No messages sent for path injection attempt",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_INJECTION_RESPONSE"
              },
              "path": ".count",
              "expected": {
                "kind": "literal",
                "value": "0"
              },
              "message": "No log messages are streamed for a path traversal attempt"
            }
          }
        },
        {
          "id": "step-connect-empty-name",
          "label": "Connect WS with service name 'lamalibre-lamaste-gatekeeper' (not in allowlist)",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs 'lamalibre-lamaste-gatekeeper' 4000"
          },
          "capture": [
            {
              "variable": "WS_GATEKEEPER_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
