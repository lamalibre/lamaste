          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_GATEKEEPER_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1008"
              },
              "message": "Service not in allowlist (lamalibre-lamaste-gatekeeper) is rejected with close code 1008"
            }
          }
        }
      ]
    }
  ]
}
