{
  "version": 1,
  "meta": {
    "number": 29,
    "name": "Service Logs WebSocket",
    "suite": "three-vm",
    "description": "29 — Service Logs WebSocket (Three-VM)",
    "deps": [1],
    "requires": ["multipass", "jq"]
  },
  "env": {},
  "constants": {},
  "apiHelpers": ["host_api_get", "host_api_post", "host_api_delete", "host_api_patch"],
  "cleanup": [],
  "sections": [
    {
      "id": "init-vars",
      "label": "Initialize variables for cleanup safety",
      "steps": [
        {
          "id": "step-init-vars",
          "label": "Initialize captured variables",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "WS_NGINX_RESPONSE=\"\"; WS_AUTHELIA_RESPONSE=\"\"; WS_CHISEL_RESPONSE=\"\"; WS_PANEL_RESPONSE=\"\"; WS_UNKNOWN_RESPONSE=\"\"; WS_INJECTION_RESPONSE=\"\"; WS_GATEKEEPER_RESPONSE=\"\"; NGINX_COUNT=\"\"; NGINX_MSG_SHAPE=\"\"; ONBOARDING_STATUS=\"\"; true"
          }
        }
      ]
    },
    {
      "id": "pre-flight-verify-onboarding-is-complete",
      "label": "Pre-flight: verify onboarding is complete",
      "steps": [
        {
          "id": "step-preflight",
          "label": "GET /api/onboarding/status",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "onboarding/status"
          },
          "capture": [
            {
              "variable": "ONBOARDING_STATUS",
              "from": {
                "kind": "jq",
                "expression": ".status"
              }
            }
          ]
        },
        {
          "id": "step-preflight-assert",
          "label": "Onboarding is COMPLETED",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "ONBOARDING_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "COMPLETED"
              },
              "message": "Onboarding is COMPLETED before running logs WS tests"
            }
          }
        }
      ]
    },
    {
      "id": "install-ws-helper",
      "label": "Install WS helper script on host",
      "steps": [
        {
          "id": "step-write-helper",
          "label": "Write Node WS client to /tmp/ws-logs-test.cjs",
          "target": "host",
          "op": {
            "type": "file",
            "action": "write",
            "path": "/tmp/ws-logs-test.cjs",
            "mode": "0644",
            "content": "const WebSocket = require('ws');\nconst fs = require('fs');\nconst svc = process.argv[2];\nconst timeoutMs = parseInt(process.argv[3] || '5000', 10);\nconst url = 'wss://127.0.0.1:9292/api/services/' + svc + '/logs';\nconst ws = new WebSocket(url, {\n  cert: fs.readFileSync('/etc/lamalibre/lamaste/pki/client.crt'),\n  key: fs.readFileSync('/etc/lamalibre/lamaste/pki/client.key'),\n  ca: fs.readFileSync('/etc/lamalibre/lamaste/pki/ca.crt'),\n  rejectUnauthorized: false,\n});\nlet received = 0;\nconst out = { opened: false, messages: [], closeCode: null, closeReason: null, error: null, count: 0 };\nconst t = setTimeout(function() { try { ws.close(); } catch (e) {} finish(); }, timeoutMs);\nfunction finish() { clearTimeout(t); console.log(JSON.stringify(out)); process.exit(0); }\nws.on('open', function() { out.opened = true; });\nws.on('message', function(data) {\n  received++;\n  if (out.messages.length < 3) out.messages.push(data.toString().slice(0, 300));\n});\nws.on('close', function(code, reason) { out.closeCode = code; out.closeReason = reason.toString(); out.count = received; finish(); });\nws.on('error', function(err) { out.error = err.message; });\n"
          }
        },
        {
          "id": "step-verify-helper",
          "label": "Helper script exists on host",
          "target": "host",
          "op": {
            "type": "file",
            "action": "exists",
            "path": "/tmp/ws-logs-test.cjs"
          }
        }
      ]
    },
    {
      "id": "happy-path-nginx",
      "label": "Happy path: stream logs for nginx",
      "steps": [
        {
          "id": "step-connect-nginx",
          "label": "Connect WS to /api/services/nginx/logs",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs nginx 4000"
          },
          "capture": [
            {
              "variable": "WS_NGINX_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-nginx-opened",
          "label": "WS opened for nginx",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_NGINX_RESPONSE"
              },
              "path": ".opened",
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "WebSocket upgrade succeeds for nginx (opened: true)"
            }
          }
        },
        {
          "id": "step-nginx-close-1000",
          "label": "Close code is 1000 for nginx",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
                "kind": "var",
                "name": "WS_NGINX_RESPONSE"
              },
              "path": ".closeCode",
              "expected": {
                "kind": "literal",
                "value": "1000"
              },
              "message": "nginx logs stream closes with code 1000 (normal)"
            }
          }
        },
        {
          "id": "step-nginx-has-messages",
          "label": "Extract nginx message count",
          "target": "local",
          "op": {
            "type": "set",
            "variable": "NGINX_COUNT",
            "from": {
              "kind": "jq",
              "input": {
                "kind": "var",
                "name": "WS_NGINX_RESPONSE"
              },
              "expression": ".count"
            }
          }
        },
        {
          "id": "step-nginx-count-nonempty",
          "label": "At least one log message received for nginx",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "truthy",
              "value": {
                "kind": "var",
                "name": "NGINX_COUNT"
              },
              "message": "nginx logs stream delivered at least one message (count > 0)"
            }
          }
        },
        {
          "id": "step-nginx-msg-shape",
          "label": "First message is valid JSON with timestamp and message fields",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "echo \"${WS_NGINX_RESPONSE}\" | jq -r '.messages[0]' | jq -r 'has(\"timestamp\") and has(\"message\")'"
          },
          "capture": [
            {
              "variable": "NGINX_MSG_SHAPE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-nginx-msg-shape-assert",
          "label": "nginx log messages have timestamp and message fields",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "NGINX_MSG_SHAPE"
              },
              "expected": {
                "kind": "literal",
                "value": "true"
              },
              "message": "First nginx log message has 'timestamp' and 'message' fields"
            }
          }
        }
      ]
    },
    {
      "id": "other-allowed-services",
      "label": "Other allowed services accept WS upgrade",
      "steps": [
        {
          "id": "step-connect-authelia",
          "label": "Connect WS to /api/services/authelia/logs",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "NODE_PATH=/opt/lamalibre/lamaste/serverd/node_modules node /tmp/ws-logs-test.cjs authelia 4000"
          },
          "capture": [
            {
              "variable": "WS_AUTHELIA_RESPONSE",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-authelia-opened",
          "label": "authelia WS opened",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "json_field",
              "source": {
