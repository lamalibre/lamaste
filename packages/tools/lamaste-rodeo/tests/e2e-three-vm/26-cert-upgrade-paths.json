          "label": "PATCH allowed-sites with invalid site name (UPPERCASE) → 4xx",
          "target": "host",
          "op": {
            "type": "exec",
            "command": "curl -sk -o /dev/null -w '%{http_code}' --max-time 30 --cert /etc/lamalibre/lamaste/pki/client.crt --key /etc/lamalibre/lamaste/pki/client.key --cacert /etc/lamalibre/lamaste/pki/ca.crt -X PATCH -H 'Content-Type: application/json' -H 'Accept: application/json' -d '{\"allowedSites\":[\"INVALID-UPPERCASE\"]}' https://127.0.0.1:9292/api/certs/agent/cert-upgrade-agent/allowed-sites 2>/dev/null || echo 000"
          },
          "capture": [
