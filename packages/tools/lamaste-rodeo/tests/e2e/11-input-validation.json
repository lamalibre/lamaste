        },
        {
          "id": "step-29",
          "label": "Subdomain with path traversal rejected (HTTP 400)",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "INJECT_TRAVERSAL_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "Subdomain with path traversal rejected (HTTP 400)"
            }
          }
        },
        {
          "id": "step-30",
          "label": "POST /api/tunnels",
          "target": "host",
          "op": {
            "type": "api",
            "method": "POST",
            "path": "tunnels",
            "body": {
              "subdomain": "TEST-UPPER",
              "port": 19004,
              "description": "uppercase test"
            },
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "INJECT_UPPER_STATUS",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
