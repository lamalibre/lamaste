            }
          ]
        },
        {
          "id": "step-19",
          "label": "POST /api/certs/a..b/renew returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "CERT_DOUBLE_DOT_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "POST /api/certs/a..b/renew returns 400"
            }
          }
        },
        {
          "id": "step-20",
          "label": "POST /api/certs/.../renew",
          "target": "host",
          "op": {
            "type": "api",
            "method": "POST",
            "path": "certs/.../renew",
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "CERT_DOTS_STATUS",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
          "id": "step-21",
          "label": "POST /api/certs/.../renew returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "CERT_DOTS_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "POST /api/certs/.../renew returns 400"
            }
          }
        },
        {
          "id": "step-22",
          "label": "POST /api/certs/evil.com;inject/renew",
          "target": "host",
          "op": {
            "type": "api",
            "method": "POST",
            "path": "certs/evil.com;inject/renew",
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "CERT_INJECT_STATUS",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
          "id": "step-23",
          "label": "POST /api/certs/evil.com;inject/renew returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "CERT_INJECT_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "POST /api/certs/evil.com;inject/renew returns 400"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Invalid domain format in certs endpoint\"\n# ---------------------------------------------------------------------------\n\nCERT_DOUBLE_DOT_STATUS=$(api_post_status \"certs/a..b/renew\")\nassert_eq \"$CERT_DOUBLE_DOT_STATUS\" \"400\" \"POST /api/certs/a..b/renew returns 400\" || true\n\nCERT_DOTS_STATUS=$(api_post_status \"certs/.../renew\")\nassert_eq \"$CERT_DOTS_STATUS\" \"400\" \"POST /api/certs/.../renew returns 400\" || true\n\nCERT_INJECT_STATUS=$(api_post_status \"certs/evil.com;inject/renew\")\nassert_eq \"$CERT_INJECT_STATUS\" \"400\" \"POST /api/certs/evil.com;inject/renew returns 400\" || true\n\n# ===========================================================================\n# 5. Subdomain injection attempts for tunnels\n# ==========================================================================="
    },
    {
      "id": "subdomain-injection-attempts",
      "label": "Subdomain injection attempts",
      "steps": [
        {
