{
  "version": 1,
  "meta": {
    "number": 11,
    "name": "Input Validation & Security Hardening",
    "suite": "e2e",
    "description": "11 — Input Validation & Security Hardening",
    "deps": [],
    "requires": ["curl", "jq"]
  },
  "env": {},
  "constants": {},
  "cleanup": [],
  "sections": [
    {
      "id": "pre-flight-check-onboarding-is-complete",
      "label": "Pre-flight: check onboarding is complete",
      "steps": [
        {
          "id": "step-0",
          "label": "GET /api/onboarding/status",
          "target": "host",
          "op": {
            "type": "api",
            "method": "GET",
            "path": "onboarding/status"
          },
          "capture": [
            {
              "variable": "ONBOARDING_STATUS",
              "from": {
                "kind": "jq",
                "expression": ".status"
              }
            }
          ]
        }
      ],
      "when": {
        "kind": "var_eq",
        "variable": "ONBOARDING_STATUS",
        "value": "COMPLETED"
      },
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Pre-flight: check onboarding is complete\"\n# ---------------------------------------------------------------------------\n\nONBOARDING_STATUS=$(api_get \"onboarding/status\" | jq -r '.status' 2>/dev/null || echo \"unknown\")\nif [ \"$ONBOARDING_STATUS\" != \"COMPLETED\" ]; then\n  log_skip \"Skipping validation tests — onboarding not complete\"\n  end_test\n  exit $?\nfi\n\n# ===========================================================================\n# 1. Invalid UUID for tunnel operations\n# ==========================================================================="
    },
    {
      "id": "invalid-uuid-for-tunnel-operations",
      "label": "Invalid UUID for tunnel operations",
      "steps": [
        {
          "id": "step-1",
          "label": "PATCH /api/tunnels/not-a-uuid",
          "target": "host",
          "op": {
            "type": "api",
            "method": "PATCH",
            "path": "tunnels/not-a-uuid",
            "body": {
              "enabled": false
            },
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "PATCH_BAD_UUID_STATUS",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
          "id": "step-2",
          "label": "PATCH /api/tunnels/not-a-uuid returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "PATCH_BAD_UUID_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "PATCH /api/tunnels/not-a-uuid returns 400"
            }
          }
        },
        {
          "id": "step-3",
          "label": "DELETE /api/tunnels/not-a-uuid",
          "target": "host",
          "op": {
            "type": "api",
            "method": "DELETE",
            "path": "tunnels/not-a-uuid",
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "DELETE_BAD_UUID_STATUS",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
          "id": "step-4",
          "label": "DELETE /api/tunnels/not-a-uuid returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "DELETE_BAD_UUID_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "DELETE /api/tunnels/not-a-uuid returns 400"
            }
          }
        },
        {
          "id": "step-5",
          "label": "PATCH /api/tunnels/../etc/passwd",
          "target": "host",
          "op": {
            "type": "api",
            "method": "PATCH",
            "path": "tunnels/../etc/passwd",
            "body": {
              "enabled": false
            },
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "PATCH_TRAVERSAL_STATUS",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
          "id": "step-6",
          "label": "PATCH /api/tunnels/../etc/passwd rejected (HTTP $PATCH_TRAVERSAL_STATUS)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "pass",
            "message": "PATCH /api/tunnels/../etc/passwd rejected (HTTP $PATCH_TRAVERSAL_STATUS)"
          },
          "when": {
            "kind": "or",
            "conditions": [
              {
                "kind": "var_eq",
                "variable": "PATCH_TRAVERSAL_STATUS",
                "value": "400"
              },
              {
                "kind": "var_eq",
                "variable": "PATCH_TRAVERSAL_STATUS",
                "value": "404"
              }
            ]
          }
        },
        {
          "id": "step-7",
          "label": "PATCH /api/tunnels/../etc/passwd should be rejected (got HTTP $PATCH_TRAVERSAL_STATUS)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "fail",
            "message": "PATCH /api/tunnels/../etc/passwd should be rejected (got HTTP $PATCH_TRAVERSAL_STATUS)"
          },
          "when": {
            "kind": "and",
            "conditions": [
              {
                "kind": "var_not_eq",
                "variable": "PATCH_TRAVERSAL_STATUS",
                "value": "400"
              },
              {
                "kind": "var_not_eq",
                "variable": "PATCH_TRAVERSAL_STATUS",
                "value": "404"
              }
            ]
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Invalid UUID for tunnel operations\"\n# ---------------------------------------------------------------------------\n\nPATCH_BAD_UUID_STATUS=$(api_patch_status \"tunnels/not-a-uuid\" '{\"enabled\": false}')\nassert_eq \"$PATCH_BAD_UUID_STATUS\" \"400\" \"PATCH /api/tunnels/not-a-uuid returns 400\" || true\n\nDELETE_BAD_UUID_STATUS=$(api_delete_status \"tunnels/not-a-uuid\")\nassert_eq \"$DELETE_BAD_UUID_STATUS\" \"400\" \"DELETE /api/tunnels/not-a-uuid returns 400\" || true\n\n# Path traversal: curl normalizes ../etc/passwd so this becomes /api/etc/passwd → 404\nPATCH_TRAVERSAL_STATUS=$(api_patch_status \"tunnels/../etc/passwd\" '{\"enabled\": false}')\nif [ \"$PATCH_TRAVERSAL_STATUS\" = \"400\" ] || [ \"$PATCH_TRAVERSAL_STATUS\" = \"404\" ]; then\n  log_pass \"PATCH /api/tunnels/../etc/passwd rejected (HTTP $PATCH_TRAVERSAL_STATUS)\"\nelse\n  log_fail \"PATCH /api/tunnels/../etc/passwd should be rejected (got HTTP $PATCH_TRAVERSAL_STATUS)\"\nfi\n\n# ===========================================================================\n# 2. Invalid UUID for site operations\n# ==========================================================================="
    },
    {
      "id": "invalid-uuid-for-site-operations",
      "label": "Invalid UUID for site operations",
      "steps": [
        {
          "id": "step-8",
          "label": "DELETE /api/sites/not-a-uuid",
          "target": "host",
          "op": {
            "type": "api",
            "method": "DELETE",
            "path": "sites/not-a-uuid",
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "DELETE_SITE_BAD_UUID",
              "from": {
                "kind": "status"
              }
            }
          ]
        },
        {
          "id": "step-9",
          "label": "DELETE /api/sites/not-a-uuid returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "DELETE_SITE_BAD_UUID"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "DELETE /api/sites/not-a-uuid returns 400"
            }
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Invalid UUID for site operations\"\n# ---------------------------------------------------------------------------\n\nDELETE_SITE_BAD_UUID=$(api_delete_status \"sites/not-a-uuid\")\nassert_eq \"$DELETE_SITE_BAD_UUID\" \"400\" \"DELETE /api/sites/not-a-uuid returns 400\" || true\n\n# ===========================================================================\n# 3. Invalid invite token format\n# ==========================================================================="
    },
    {
      "id": "invalid-invite-token-format",
      "label": "Invalid invite token format",
      "steps": [
        {
          "id": "step-10",
          "label": "Set INVITE_GET_STATUS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls -o /dev/null -w '%{http_code}' \"${BASE_URL}/api/invite/not-a-valid-token\" 2>/dev/null || echo \"000\""
          },
          "capture": [
            {
              "variable": "INVITE_GET_STATUS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-11",
          "label": "GET /api/invite/not-a-valid-token returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "INVITE_GET_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "GET /api/invite/not-a-valid-token returns 400"
            }
          }
        },
        {
          "id": "step-12",
          "label": "Set INVITE_POST_STATUS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls -o /dev/null -w '%{http_code}' -X POST -H \"Content-Type: application/json\" -d '{\"password\":\"Test1234!!\",\"confirmPassword\":\"Test1234!!\"}' \"${BASE_URL}/api/invite/not-a-valid-token/accept\" 2>/dev/null || echo \"000\""
          },
          "capture": [
            {
              "variable": "INVITE_POST_STATUS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-13",
          "label": "POST /api/invite/not-a-valid-token/accept returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "INVITE_POST_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "POST /api/invite/not-a-valid-token/accept returns 400"
            }
          }
        },
        {
          "id": "step-14",
          "label": "Set INVITE_TRAVERSAL_STATUS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls -o /dev/null -w '%{http_code}' \"${BASE_URL}/api/invite/../../etc/passwd\" 2>/dev/null || echo \"000\""
          },
          "capture": [
            {
              "variable": "INVITE_TRAVERSAL_STATUS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-15",
          "label": "Set INVITE_TRAVERSAL_BODY",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls \"${BASE_URL}/api/invite/../../etc/passwd\" 2>/dev/null || echo \"\""
          },
          "capture": [
            {
              "variable": "INVITE_TRAVERSAL_BODY",
              "from": {
                "kind": "body"
              }
            }
          ],
          "when": {
            "kind": "or",
            "conditions": [
              {
                "kind": "var_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "400"
              },
              {
                "kind": "var_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "404"
              },
              {
                "kind": "var_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "200"
              }
            ]
          }
        },
        {
          "id": "step-16",
          "label": "Path traversal does not expose /etc/passwd",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "not_contains",
              "actual": {
                "kind": "var",
                "name": "INVITE_TRAVERSAL_BODY"
              },
              "substring": {
                "kind": "literal",
                "value": "root:"
              },
              "message": "Path traversal does not expose /etc/passwd"
            }
          },
          "when": {
            "kind": "or",
            "conditions": [
              {
                "kind": "var_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "400"
              },
              {
                "kind": "var_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "404"
              },
              {
                "kind": "var_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "200"
              }
            ]
          }
        },
        {
          "id": "step-17",
          "label": "GET /api/invite/../../etc/passwd returned unexpected status $INVITE_TRAVERSAL_STATUS",
          "target": "local",
          "op": {
            "type": "log",
            "level": "fail",
            "message": "GET /api/invite/../../etc/passwd returned unexpected status $INVITE_TRAVERSAL_STATUS"
          },
          "when": {
            "kind": "and",
            "conditions": [
              {
                "kind": "var_not_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "400"
              },
              {
                "kind": "var_not_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "404"
              },
              {
                "kind": "var_not_eq",
                "variable": "INVITE_TRAVERSAL_STATUS",
                "value": "200"
              }
            ]
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Invalid invite token format\"\n# ---------------------------------------------------------------------------\n\n# Invite routes may or may not require mTLS. Try with mTLS first (via _curl_mtls).\nINVITE_GET_STATUS=$(_curl_mtls -o /dev/null -w '%{http_code}' \\\n  \"${BASE_URL}/api/invite/not-a-valid-token\" 2>/dev/null || echo \"000\")\nassert_eq \"$INVITE_GET_STATUS\" \"400\" \"GET /api/invite/not-a-valid-token returns 400\" || true\n\nINVITE_POST_STATUS=$(_curl_mtls -o /dev/null -w '%{http_code}' \\\n  -X POST \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"password\":\"Test1234!!\",\"confirmPassword\":\"Test1234!!\"}' \\\n  \"${BASE_URL}/api/invite/not-a-valid-token/accept\" 2>/dev/null || echo \"000\")\nassert_eq \"$INVITE_POST_STATUS\" \"400\" \"POST /api/invite/not-a-valid-token/accept returns 400\" || true\n\n# Path traversal: curl normalizes ../../etc/passwd so this becomes /etc/passwd → 200 (SPA fallback)\n# or 400/404 depending on normalization. The key is it doesn't expose files.\nINVITE_TRAVERSAL_STATUS=$(_curl_mtls -o /dev/null -w '%{http_code}' \\\n  \"${BASE_URL}/api/invite/../../etc/passwd\" 2>/dev/null || echo \"000\")\nif [ \"$INVITE_TRAVERSAL_STATUS\" = \"400\" ] || [ \"$INVITE_TRAVERSAL_STATUS\" = \"404\" ] || [ \"$INVITE_TRAVERSAL_STATUS\" = \"200\" ]; then\n  # Verify it doesn't return actual file content (ensure no real path traversal)\n  INVITE_TRAVERSAL_BODY=$(_curl_mtls \"${BASE_URL}/api/invite/../../etc/passwd\" 2>/dev/null || echo \"\")\n  assert_not_contains \"$INVITE_TRAVERSAL_BODY\" \"root:\" \"Path traversal does not expose /etc/passwd\" || true\nelse\n  log_fail \"GET /api/invite/../../etc/passwd returned unexpected status $INVITE_TRAVERSAL_STATUS\"\nfi\n\n# ===========================================================================\n# 4. Invalid domain format in certs endpoint\n# ==========================================================================="
    },
    {
      "id": "invalid-domain-format-in-certs-endpoint",
      "label": "Invalid domain format in certs endpoint",
      "steps": [
        {
          "id": "step-18",
          "label": "POST /api/certs/a..b/renew",
          "target": "host",
          "op": {
            "type": "api",
            "method": "POST",
            "path": "certs/a..b/renew",
            "statusOnly": true
          },
          "capture": [
            {
              "variable": "CERT_DOUBLE_DOT_STATUS",
