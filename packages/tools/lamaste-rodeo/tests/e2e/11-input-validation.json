      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Port boundary validation\"\n# ---------------------------------------------------------------------------\n\nPORT_ZERO_STATUS=$(api_post_status \"tunnels\" '{\"subdomain\":\"e2eport0\",\"port\":0,\"description\":\"port zero\"}')\nassert_eq \"$PORT_ZERO_STATUS\" \"400\" \"Port 0 rejected (HTTP 400)\" || true\n\nPORT_LOW_STATUS=$(api_post_status \"tunnels\" '{\"subdomain\":\"e2eport1023\",\"port\":1023,\"description\":\"port 1023\"}')\nassert_eq \"$PORT_LOW_STATUS\" \"400\" \"Port 1023 rejected (HTTP 400)\" || true\n\nPORT_HIGH_STATUS=$(api_post_status \"tunnels\" '{\"subdomain\":\"e2eport65536\",\"port\":65536,\"description\":\"port 65536\"}')\nassert_eq \"$PORT_HIGH_STATUS\" \"400\" \"Port 65536 rejected (HTTP 400)\" || true\n\nPORT_NEG_STATUS=$(api_post_status \"tunnels\" '{\"subdomain\":\"e2eportneg\",\"port\":-1,\"description\":\"port negative\"}')\nassert_eq \"$PORT_NEG_STATUS\" \"400\" \"Port -1 rejected (HTTP 400)\" || true\n\nPORT_STR_STATUS=$(api_post_status \"tunnels\" '{\"subdomain\":\"e2eportstr\",\"port\":\"abc\",\"description\":\"port string\"}')\nassert_eq \"$PORT_STR_STATUS\" \"400\" \"Port 'abc' (string) rejected (HTTP 400)\" || true\n\n# ===========================================================================\n# 7. Malformed JSON bodies\n# ==========================================================================="
    },
    {
      "id": "malformed-json-bodies",
      "label": "Malformed JSON bodies",
      "steps": [
        {
          "id": "step-45",
          "label": "Set MALFORMED_STATUS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls -o /dev/null -w '%{http_code}' -X POST -H \"Content-Type: application/json\" -d '{this is not valid json' \"${BASE_URL}/api/tunnels\" 2>/dev/null || echo \"000\""
          },
          "capture": [
            {
              "variable": "MALFORMED_STATUS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-46",
          "label": "Invalid JSON body to /api/tunnels returns 400",
          "target": "local",
          "continueOnError": true,
          "op": {
            "type": "assert",
            "check": {
              "kind": "eq",
              "actual": {
                "kind": "var",
                "name": "MALFORMED_STATUS"
              },
              "expected": {
                "kind": "literal",
                "value": "400"
              },
              "message": "Invalid JSON body to /api/tunnels returns 400"
            }
          }
        },
        {
          "id": "step-47",
          "label": "Set EMPTY_BODY_STATUS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "_curl_mtls -o /dev/null -w '%{http_code}' -X POST -H \"Content-Type: application/json\" -d '' \"${BASE_URL}/api/users\" 2>/dev/null || echo \"000\""
          },
          "capture": [
            {
              "variable": "EMPTY_BODY_STATUS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-48",
          "label": "Empty body to /api/users rejected (HTTP $EMPTY_BODY_STATUS)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "pass",
            "message": "Empty body to /api/users rejected (HTTP $EMPTY_BODY_STATUS)"
          },
          "when": {
            "kind": "or",
            "conditions": [
              {
                "kind": "var_eq",
                "variable": "EMPTY_BODY_STATUS",
                "value": "400"
              },
              {
                "kind": "var_eq",
                "variable": "EMPTY_BODY_STATUS",
                "value": "422"
              }
            ]
          }
        },
        {
          "id": "step-49",
          "label": "Empty body to /api/users should be rejected (got HTTP $EMPTY_BODY_STATUS)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "fail",
            "message": "Empty body to /api/users should be rejected (got HTTP $EMPTY_BODY_STATUS)"
          },
          "when": {
            "kind": "and",
            "conditions": [
              {
                "kind": "var_not_eq",
                "variable": "EMPTY_BODY_STATUS",
                "value": "400"
              },
              {
                "kind": "var_not_eq",
                "variable": "EMPTY_BODY_STATUS",
                "value": "422"
              }
            ]
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"Malformed JSON bodies\"\n# ---------------------------------------------------------------------------\n\n# POST with invalid JSON (not parseable)\nMALFORMED_STATUS=$(_curl_mtls -o /dev/null -w '%{http_code}' \\\n  -X POST \\\n  -H \"Content-Type: application/json\" \\\n  -d '{this is not valid json' \\\n  \"${BASE_URL}/api/tunnels\" 2>/dev/null || echo \"000\")\nassert_eq \"$MALFORMED_STATUS\" \"400\" \"Invalid JSON body to /api/tunnels returns 400\" || true\n\n# POST with empty body to /api/users\nEMPTY_BODY_STATUS=$(_curl_mtls -o /dev/null -w '%{http_code}' \\\n  -X POST \\\n  -H \"Content-Type: application/json\" \\\n  -d '' \\\n  \"${BASE_URL}/api/users\" 2>/dev/null || echo \"000\")\nif [ \"$EMPTY_BODY_STATUS\" = \"400\" ] || [ \"$EMPTY_BODY_STATUS\" = \"422\" ]; then\n  log_pass \"Empty body to /api/users rejected (HTTP $EMPTY_BODY_STATUS)\"\nelse\n  log_fail \"Empty body to /api/users should be rejected (got HTTP $EMPTY_BODY_STATUS)\"\nfi\n\n# ===========================================================================\n# 8. File permissions check\n# ==========================================================================="
    },
    {
      "id": "file-permissions",
      "label": "File permissions",
      "steps": [
        {
          "id": "step-51",
          "label": "Set PERMS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "stat -c '%a' \"$f\" 2>/dev/null || stat -f '%Lp' \"$f\" 2>/dev/null || echo \"unknown\""
          },
          "capture": [
            {
              "variable": "PERMS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-52",
          "label": "$f has correct permissions (600)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "pass",
            "message": "$f has correct permissions (600)"
          },
          "when": {
            "kind": "var_eq",
            "variable": "PERMS",
            "value": "600"
          }
        },
        {
          "id": "step-53",
          "label": "$f has permissions $PERMS (expected 600)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "fail",
            "message": "$f has permissions $PERMS (expected 600)"
          },
          "when": {
            "kind": "var_not_eq",
            "variable": "PERMS",
            "value": "600"
          }
        },
        {
          "id": "step-54",
          "label": "$f not found",
          "target": "local",
          "op": {
            "type": "log",
            "level": "skip",
            "message": "$f not found"
          }
        },
        {
          "id": "step-56",
          "label": "Set PERMS",
          "target": "local",
          "op": {
            "type": "exec",
            "command": "stat -c '%a' /etc/lamalibre/lamaste/panel.json 2>/dev/null || stat -f '%Lp' /etc/lamalibre/lamaste/panel.json 2>/dev/null || echo \"unknown\""
          },
          "capture": [
            {
              "variable": "PERMS",
              "from": {
                "kind": "body"
              }
            }
          ]
        },
        {
          "id": "step-57",
          "label": "panel.json has correct permissions ($PERMS)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "pass",
            "message": "panel.json has correct permissions ($PERMS)"
          },
          "when": {
            "kind": "or",
            "conditions": [
              {
                "kind": "var_eq",
                "variable": "PERMS",
                "value": "600"
              },
              {
                "kind": "var_eq",
                "variable": "PERMS",
                "value": "640"
              }
            ]
          }
        },
        {
          "id": "step-58",
          "label": "panel.json has permissions $PERMS (expected 600 or 640)",
          "target": "local",
          "op": {
            "type": "log",
            "level": "fail",
            "message": "panel.json has permissions $PERMS (expected 600 or 640)"
          },
          "when": {
            "kind": "and",
            "conditions": [
              {
                "kind": "var_not_eq",
                "variable": "PERMS",
                "value": "600"
              },
              {
                "kind": "var_not_eq",
                "variable": "PERMS",
                "value": "640"
              }
            ]
          }
        }
      ],
      "bash": "# ---------------------------------------------------------------------------\nlog_section \"File permissions\"\n# ---------------------------------------------------------------------------\n\n# Check state files have restrictive permissions\nfor f in /etc/lamalibre/lamaste/tunnels.json /etc/lamalibre/lamaste/sites.json; do\n  if [ -f \"$f\" ]; then\n    PERMS=$(stat -c '%a' \"$f\" 2>/dev/null || stat -f '%Lp' \"$f\" 2>/dev/null || echo \"unknown\")\n    if [ \"$PERMS\" = \"600\" ]; then\n      log_pass \"$f has correct permissions (600)\"\n    else\n      log_fail \"$f has permissions $PERMS (expected 600)\"\n    fi\n  else\n    log_skip \"$f not found\"\n  fi\ndone\n\n# Check panel.json permissions\nif [ -f /etc/lamalibre/lamaste/panel.json ]; then\n  PERMS=$(stat -c '%a' /etc/lamalibre/lamaste/panel.json 2>/dev/null || stat -f '%Lp' /etc/lamalibre/lamaste/panel.json 2>/dev/null || echo \"unknown\")\n  if [ \"$PERMS\" = \"600\" ] || [ \"$PERMS\" = \"640\" ]; then\n    log_pass \"panel.json has correct permissions ($PERMS)\"\n  else\n    log_fail \"panel.json has permissions $PERMS (expected 600 or 640)\"\n  fi\nfi"
    }
  ],
  "apiHelpers": [],
  "headerRaw": "# ============================================================================\n# 11 — Input Validation & Security Hardening\n# ============================================================================\n# Verifies that API endpoints properly validate and reject malicious input:\n# - Invalid UUID route parameters\n# - Invalid token format\n# - Invalid domain format in certs endpoint\n# - Subdomain injection attempts\n# - Invalid port values\n# - Invalid JSON bodies\n# - Path traversal attempts (where applicable)\n# ============================================================================",
  "preambleRaw": "\nset -euo pipefail\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nsource \"${SCRIPT_DIR}/helpers.sh\"\n\nrequire_commands curl jq\n\nbegin_test \"11 — Input Validation & Security Hardening\"\n",
  "cleanupRaw": "",
  "trailerRaw": "\nend_test\n"
}
